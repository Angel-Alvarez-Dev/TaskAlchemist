# 🔮 Notion API Configuration
NOTION_TOKEN=your_notion_integration_token_here   # Token de integración con Notion
NOTION_DATABASE_ID=your_notion_database_id_here   # ID de la base de datos de Notion

# 📂 Directorios y Archivos
BASE_DOCUMENTS_PATH=./documents    # Ruta base donde se guardarán los documentos

# ⚙️ Opciones de Automatización
AUTO_OPEN_FILE=true   # Abre automáticamente los archivos generados (true/false)
AUTO_CONVERT_PDF=true  # Convierte automáticamente a PDF después de generar (true/false)
MONITOR_NOTION_CHANGES=false  # Habilita el monitoreo automático de Notion (true/false)

# 🕒 Configuración de Tareas Programadas
TASK_CHECK_INTERVAL=10  # Tiempo en segundos entre revisiones de Notion
